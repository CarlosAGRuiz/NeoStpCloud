@model NeoSTP.Application.Common.PagedResult<NeoSTP.Application.Productos.Dtos.ProductoDto>
@{
    ViewData["Title"] = "Productos";
    var search = ViewBag.Search as string;
}

@if (TempData["Success"] is string ok) { <div class="alert alert-success">@ok</div> }
@if (TempData["Error"] is string err) { <div class="alert alert-danger">@err</div> }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h4 m-0">Productos y servicios</h1>
    <a asp-action="Create" class="btn btn-primary btn-sm">+ Nuevo</a>
</div>

<form method="get" class="row g-2 mb-3">
    <div class="col-auto">
        <input name="search" value="@search" class="form-control form-control-sm" placeholder="Buscar código, nombre o barra…" />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-outline-secondary btn-sm">Buscar</button>
    </div>
</form>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover m-0 align-middle">
            <thead class="table-light">
                <tr>
                    <th>Código</th>
                    <th>Nombre</th>
                    <th>Tipo</th>
                    <th>UM</th>
                    <th class="text-end">Precio</th>
                    <th>IVA</th>
                    <th>Estado</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (Model is null || !Model.Items.Any())
                {
                    <tr><td colspan="8" class="text-center text-muted py-4">Sin productos.</td></tr>
                }
                @foreach (var p in Model?.Items ?? Array.Empty<NeoSTP.Application.Productos.Dtos.ProductoDto>())
                {
                    var badge = p.EstadoCodigo == "ACTIVO" ? "bg-success" : "bg-secondary";
                    var tipoBadge = p.EsServicio ? "bg-warning text-dark" : "bg-info";
                    <tr>
                        <td><strong>@p.CodigoInterno</strong>@(p.CodigoBarra is null ? "" : $" / {p.CodigoBarra}")</td>
                        <td>@p.Nombre<br /><small class="text-muted">@p.Descripcion</small></td>
                        <td><span class="badge @tipoBadge">@p.TipoItem</span></td>
                        <td><small>@p.UnidadMedidaCodigo</small></td>
                        <td class="text-end">@p.PrecioUnitario.ToString("N4")</td>
                        <td>@(p.AplicaIva ? "✓" : "—")</td>
                        <td><span class="badge @badge">@p.EstadoCodigo</span></td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-sm btn-outline-primary">Editar</a>
                            @if (p.EstadoCodigo == "ACTIVO")
                            {
                                <form asp-action="Inactivar" asp-route-id="@p.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-sm btn-outline-danger" onclick="return confirm('¿Inactivar este producto?');">Inactivar</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (Model is not null && Model.TotalPages > 1)
{
    <nav class="mt-3"><ul class="pagination pagination-sm">
        @for (int i = 1; i <= Model.TotalPages; i++)
        {
            <li class="page-item @(i == Model.Page ? "active" : "")">
                <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-search="@search">@i</a>
            </li>
        }
    </ul></nav>
}

<p class="text-muted small mt-2">Total: @(Model?.Total ?? 0) productos.</p>
