@model IReadOnlyList<NeoSTP.Application.Licenciamiento.Dtos.PlanDto>
@{ ViewData["Title"] = "Planes"; }

<h1 class="h4 mb-3">Planes disponibles</h1>

<div class="row g-3">
    @foreach (var p in Model ?? Array.Empty<NeoSTP.Application.Licenciamiento.Dtos.PlanDto>())
    {
        <div class="col-md-6 col-lg-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <h2 class="h5 mb-0">@p.Nombre</h2>
                        <span class="badge bg-secondary">@p.Codigo</span>
                    </div>
                    <p class="text-muted small mb-3">@p.Descripcion</p>
                    <div class="display-6 mb-2">@p.MonedaCodigo @p.PrecioMensual.ToString("N2") <small class="text-muted h6">/mes</small></div>
                    <ul class="list-unstyled small mb-3">
                        <li>👤 Usuarios: <strong>@(p.LimiteUsuarios?.ToString() ?? "ilimitado")</strong></li>
                        <li>🏪 Sucursales: <strong>@(p.LimiteSucursales?.ToString() ?? "ilimitado")</strong></li>
                        <li>🛒 Puntos de venta: <strong>@(p.LimitePuntosVenta?.ToString() ?? "ilimitado")</strong></li>
                        <li>📄 DTE/mes: <strong>@(p.LimiteDteMensual?.ToString("N0") ?? "ilimitado")</strong></li>
                    </ul>
                    <div class="mt-3">
                        <strong class="small text-muted">Incluye módulos:</strong>
                        <div class="mt-1">
                            @foreach (var m in p.Modulos.OrderBy(x => x.Orden))
                            {
                                <span class="badge bg-light text-dark border me-1 mb-1">@m.Codigo</span>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
