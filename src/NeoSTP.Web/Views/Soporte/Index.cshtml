@model NeoSTP.Application.Common.PagedResult<NeoSTP.Application.Empresas.Dtos.EmpresaDto>
@{
    ViewData["Title"] = "Modo soporte · Seleccionar empresa";
    var search = ViewBag.Search as string;
    var currentEmpresaId = ViewBag.CurrentEmpresaId as int?;
}

@if (TempData["Success"] is string ok) { <div class="alert alert-success">@ok</div> }
@if (TempData["Error"] is string err) { <div class="alert alert-danger">@err</div> }

<h1 class="h4 mb-3">Modo soporte · Operar como empresa</h1>
<p class="text-muted">Como SuperAdmin no perteneces a ninguna empresa. Selecciona una para operar las pantallas de Clientes, Productos y Configuración DTE en su contexto.</p>

<form method="get" class="row g-2 mb-3">
    <div class="col-auto"><input name="search" value="@search" class="form-control form-control-sm" placeholder="Buscar NIT o razón social…" /></div>
    <div class="col-auto"><button type="submit" class="btn btn-outline-secondary btn-sm">Buscar</button></div>
    @if (currentEmpresaId is not null)
    {
        <div class="col-auto">
            <form asp-action="Salir" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <button class="btn btn-outline-danger btn-sm">Salir del modo soporte</button>
            </form>
        </div>
    }
</form>

<div class="card border-0 shadow-sm">
    <ul class="list-group list-group-flush">
        @foreach (var e in Model?.Items ?? Array.Empty<NeoSTP.Application.Empresas.Dtos.EmpresaDto>())
        {
            var isCurrent = currentEmpresaId == e.Id;
            <li class="list-group-item d-flex justify-content-between align-items-center @(isCurrent ? "bg-light" : "")">
                <div>
                    <strong>@e.RazonSocial</strong>
                    <span class="text-muted small">@e.Nit · @e.NombreComercial</span><br />
                    <span class="badge bg-secondary me-1">@e.EstadoCodigo</span>
                    @if (!string.IsNullOrEmpty(e.PlanActualCodigo))
                    {
                        <span class="badge bg-info">@e.PlanActualCodigo</span>
                    }
                </div>
                <div>
                    @if (isCurrent)
                    {
                        <span class="badge bg-success me-2">✓ Activa</span>
                    }
                    <form asp-action="Entrar" asp-route-id="@e.Id" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button class="btn btn-sm btn-primary">@(isCurrent ? "Recargar" : "Operar como esta empresa")</button>
                    </form>
                </div>
            </li>
        }
        @if (Model is null || !Model.Items.Any())
        {
            <li class="list-group-item text-center text-muted py-4">No hay empresas. Crea una primero en <a asp-controller="Empresas" asp-action="Create">/Empresas/Create</a>.</li>
        }
    </ul>
</div>

<p class="text-muted small mt-2">Total: @(Model?.Total ?? 0) empresas.</p>
