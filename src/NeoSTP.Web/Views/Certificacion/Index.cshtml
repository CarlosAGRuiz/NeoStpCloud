@model IReadOnlyList<NeoSTP.Application.Dte.Certificacion.Dtos.CertificacionMatrizProgresoDto>
@{
    ViewData["Title"] = "Certificación DTE";
    var resumen = ViewBag.Resumen as NeoSTP.Application.Dte.Certificacion.Dtos.CertificacionResumenDto;
    var puedeOperar = ViewBag.PuedeOperar is bool po && po;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Certificación DTE</h2>
    <div class="d-flex gap-2">
        <a asp-action="Matriz" class="btn btn-outline-primary btn-sm">📋 Matriz completa</a>
        <a asp-action="Errores" class="btn btn-outline-danger btn-sm">⚠ Errores</a>
    </div>
</div>

@if (TempData["Success"] is string ok)
{
    <div class="alert alert-success alert-dismissible fade show">@ok <button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}
@if (TempData["Error"] is string err)
{
    <div class="alert alert-danger alert-dismissible fade show">@err <button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}

@if (resumen is not null)
{
    <div class="row g-3 mb-4">
        <div class="col-md-2">
            <div class="card text-center"><div class="card-body p-2">
                <div class="text-muted small">Requeridos</div>
                <div class="h3 m-0">@resumen.Requeridos</div>
            </div></div>
        </div>
        <div class="col-md-2">
            <div class="card text-center bg-success-subtle"><div class="card-body p-2">
                <div class="text-muted small">Completados</div>
                <div class="h3 m-0 text-success">@resumen.Completados</div>
            </div></div>
        </div>
        <div class="col-md-2">
            <div class="card text-center bg-info-subtle"><div class="card-body p-2">
                <div class="text-muted small">En progreso</div>
                <div class="h3 m-0 text-info">@resumen.EnProgreso</div>
            </div></div>
        </div>
        <div class="col-md-2">
            <div class="card text-center bg-danger-subtle"><div class="card-body p-2">
                <div class="text-muted small">Con error</div>
                <div class="h3 m-0 text-danger">@resumen.ConError</div>
            </div></div>
        </div>
        <div class="col-md-2">
            <div class="card text-center"><div class="card-body p-2">
                <div class="text-muted small">Pendientes</div>
                <div class="h3 m-0 text-secondary">@resumen.Pendientes</div>
            </div></div>
        </div>
        <div class="col-md-2">
            <div class="card text-center @(resumen.ListaParaAutorizacion ? "bg-success" : "bg-light")">
                <div class="card-body p-2">
                    <div class="@(resumen.ListaParaAutorizacion ? "text-white" : "text-muted") small">Progreso</div>
                    <div class="h3 m-0 @(resumen.ListaParaAutorizacion ? "text-white" : "")">@resumen.PorcentajeProgreso%</div>
                </div>
            </div>
        </div>
    </div>

    <div class="mb-4">
        <div class="progress" style="height: 24px;">
            <div class="progress-bar bg-success" role="progressbar" style="width:@(resumen.PorcentajeProgreso)%;">
                @resumen.Completados / @resumen.Requeridos completados
            </div>
        </div>
        <small class="text-muted">
            @resumen.TiposCompletados / @resumen.TotalTipos tipos al 100%.
            @if (resumen.ListaParaAutorizacion)
            {
                <strong class="text-success">— Listo para solicitar autorización a Hacienda.</strong>
            }
        </small>
    </div>
}

<h4 class="mb-3">Progreso por tipo</h4>
<div class="row g-3">
    @foreach (var m in Model)
    {
        <div class="col-md-6 col-lg-4">
            <div class="card h-100">
                <div class="card-body p-3">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <div>
                            <div class="text-muted small">
                                @if (m.TipoDteCodigo.Length <= 2)
                                {
                                    <span>CAT-002 @m.TipoDteCodigo</span>
                                }
                                else
                                {
                                    <span>Evento</span>
                                }
                            </div>
                            <h5 class="card-title m-0">@m.Nombre</h5>
                        </div>
                        <span class="badge @(m.Completo ? "bg-success" : m.ConError > 0 ? "bg-danger" : "bg-secondary")">
                            @m.PorcentajeProgreso%
                        </span>
                    </div>
                    <div class="progress mb-2" style="height: 8px;">
                        <div class="progress-bar bg-success" style="width:@(m.Requeridos == 0 ? 0 : m.Completados * 100 / m.Requeridos)%"></div>
                        <div class="progress-bar bg-info" style="width:@(m.Requeridos == 0 ? 0 : m.EnProgreso * 100 / m.Requeridos)%"></div>
                        <div class="progress-bar bg-danger" style="width:@(m.Requeridos == 0 ? 0 : m.ConError * 100 / m.Requeridos)%"></div>
                    </div>
                    <div class="small text-muted mb-2">
                        <span class="text-success">@m.Completados ✓</span> ·
                        <span class="text-info">@m.EnProgreso ↻</span> ·
                        <span class="text-danger">@m.ConError ✗</span> ·
                        <span>@m.Pendientes pendientes</span> / @m.Requeridos
                    </div>
                    <a asp-action="Tipo" asp-route-codigo="@m.TipoDteCodigo" class="btn btn-outline-primary btn-sm">Ver escenarios</a>
                </div>
            </div>
        </div>
    }
</div>
