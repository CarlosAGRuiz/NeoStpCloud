@inject NeoSTP.Application.Empresas.IEmpresaContext EmpresaContext
@{
    var username = User.Identity?.Name;
    var isAuth = User.Identity?.IsAuthenticated ?? false;
    var tipoUsuario = User.FindFirst(NeoSTP.Web.Auth.CookieCurrentUser.ClaimTipoUsuario)?.Value;
    var isSuperAdmin = tipoUsuario == "SUPERADMIN";
    var soporteEmpresaId = EmpresaContext.CurrentEmpresaId;
    var soporteEmpresaNombre = EmpresaContext.SupportEmpresaNombre;
    var enModoSoporte = EmpresaContext.IsSupportMode;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] · NeoSTP Cloud</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/NeoSTP.Web.styles.css" asp-append-version="true" />
</head>
<body>
    @if (enModoSoporte)
    {
        <div class="bg-warning text-dark py-1 px-3 small d-flex justify-content-between align-items-center">
            <span>⚠️ <strong>Modo soporte activo</strong> · operando como: <strong>@soporteEmpresaNombre</strong></span>
            <form asp-controller="Soporte" asp-action="Salir" method="post" class="d-inline m-0">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-sm btn-link text-dark p-0">Salir del modo soporte</button>
            </form>
        </div>
    }
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-primary mb-3">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">NeoSTP Cloud</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        @if (isAuth)
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Dashboard</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Empresas" asp-action="Index">Empresas</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Clientes" asp-action="Index">Clientes</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Productos" asp-action="Index">Productos</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="DteDocumentos" asp-action="Index">DTE</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="DteConfiguracion" asp-action="Index">Config DTE</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Usuarios" asp-action="Index">Usuarios</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Planes" asp-action="Index">Planes</a></li>
                        }
                    </ul>
                    <ul class="navbar-nav">
                        @if (isAuth && isSuperAdmin)
                        {
                            <li class="nav-item">
                                <a class="btn btn-sm @(enModoSoporte ? "btn-warning" : "btn-outline-light") me-2" asp-controller="Soporte" asp-action="Index">
                                    @(enModoSoporte ? $"📍 {soporteEmpresaNombre}" : "🔧 Modo soporte")
                                </a>
                            </li>
                        }
                        @if (isAuth)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-white" data-bs-toggle="dropdown" role="button">
                                    👤 @username
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li><a class="dropdown-item" asp-controller="Account" asp-action="ChangePassword">Cambiar contraseña</a></li>
                                    <li><hr class="dropdown-divider" /></li>
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post" class="px-3 py-1">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger w-100">Cerrar sesión</button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="btn btn-outline-light btn-sm" asp-controller="Account" asp-action="Login">Iniciar sesión</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-5">
        <div class="container py-3">
            &copy; @DateTime.Now.Year NeoSTP — Plataforma SaaS DTE
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
