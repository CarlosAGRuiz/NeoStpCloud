@model NeoSTP.Web.Models.CreateClienteViewModel
@{
    var tiposDoc = (ViewBag.TiposDoc as IEnumerable<NeoSTP.Application.Catalogos.Dtos.CatalogoItemDto>) ?? Array.Empty<NeoSTP.Application.Catalogos.Dtos.CatalogoItemDto>();
    var tiposContrib = (ViewBag.TiposContrib as IEnumerable<NeoSTP.Application.Catalogos.Dtos.CatalogoItemDto>) ?? Array.Empty<NeoSTP.Application.Catalogos.Dtos.CatalogoItemDto>();
    var departamentos = (ViewBag.Departamentos as IEnumerable<NeoSTP.Application.Catalogos.Dtos.CatalogoItemDto>) ?? Array.Empty<NeoSTP.Application.Catalogos.Dtos.CatalogoItemDto>();
    var municipios = (ViewBag.Municipios as IEnumerable<NeoSTP.Application.Catalogos.Dtos.CatalogoItemDto>) ?? Array.Empty<NeoSTP.Application.Catalogos.Dtos.CatalogoItemDto>();
}

<div class="row g-3">
    <div class="col-md-4">
        <label asp-for="TipoDocumentoCodigo" class="form-label"></label>
        <select asp-for="TipoDocumentoCodigo" class="form-select">
            @foreach (var t in tiposDoc)
            {
                <option value="@t.Codigo" selected="@(t.Codigo == Model.TipoDocumentoCodigo)">@t.Valor</option>
            }
        </select>
    </div>
    <div class="col-md-4">
        <label asp-for="NumeroDocumento" class="form-label"></label>
        <input asp-for="NumeroDocumento" class="form-control" placeholder="DUI: 12345678-9 / NIT: 0614-010100-101-1" />
        <span asp-validation-for="NumeroDocumento" class="text-danger small"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="Nrc" class="form-label"></label>
        <input asp-for="Nrc" class="form-control" placeholder="1234567" />
    </div>

    <div class="col-md-6">
        <label asp-for="Nombre" class="form-label"></label>
        <input asp-for="Nombre" class="form-control" />
        <span asp-validation-for="Nombre" class="text-danger small"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="NombreComercial" class="form-label"></label>
        <input asp-for="NombreComercial" class="form-control" />
    </div>

    <div class="col-md-4">
        <label asp-for="TipoContribuyenteCodigo" class="form-label"></label>
        <select asp-for="TipoContribuyenteCodigo" class="form-select">
            @foreach (var t in tiposContrib)
            {
                <option value="@t.Codigo" selected="@(t.Codigo == Model.TipoContribuyenteCodigo)">@t.Valor</option>
            }
        </select>
    </div>
    <div class="col-md-4">
        <label asp-for="CodigoActividad" class="form-label"></label>
        <input asp-for="CodigoActividad" class="form-control" />
    </div>
    <div class="col-md-4">
        <label asp-for="ActividadEconomica" class="form-label"></label>
        <input asp-for="ActividadEconomica" class="form-control" />
    </div>

    <div class="col-md-4">
        <label asp-for="DepartamentoCodigo" class="form-label"></label>
        <select asp-for="DepartamentoCodigo" id="departamentoSelect" class="form-select">
            <option value="">—</option>
            @foreach (var d in departamentos)
            {
                <option value="@d.Codigo" selected="@(d.Codigo == Model.DepartamentoCodigo)">@d.Valor</option>
            }
        </select>
    </div>
    <div class="col-md-4">
        <label asp-for="MunicipioCodigo" class="form-label">Municipio / Zona</label>
        <select asp-for="MunicipioCodigo" id="municipioSelect" class="form-select" data-current="@Model.MunicipioCodigo">
            <option value="">— (selecciona departamento)</option>
            @foreach (var m in municipios)
            {
                <option value="@m.Codigo"
                        data-depto="@(System.Text.Json.JsonDocument.Parse(m.MetadataJson ?? "{}").RootElement.TryGetProperty("departamento", out var dp) ? dp.GetString() : "")"
                        selected="@(m.Codigo == Model.MunicipioCodigo)"
                        style="display:none">@m.Valor</option>
            }
        </select>
    </div>
    <div class="col-md-4">
        <label asp-for="Telefono" class="form-label"></label>
        <input asp-for="Telefono" class="form-control" />
    </div>

    <div class="col-md-12">
        <label asp-for="Direccion" class="form-label"></label>
        <input asp-for="Direccion" class="form-control" />
    </div>
    <div class="col-md-6">
        <label asp-for="Correo" class="form-label"></label>
        <input asp-for="Correo" type="email" class="form-control" />
        <span asp-validation-for="Correo" class="text-danger small"></span>
    </div>
</div>

<script>
(function() {
    var depto = document.getElementById('departamentoSelect');
    var muni  = document.getElementById('municipioSelect');
    if (!depto || !muni) return;

    function filter() {
        var selected = depto.value;
        var currentMuni = muni.value;
        var foundCurrent = false;
        Array.prototype.forEach.call(muni.options, function(opt) {
            if (!opt.value) { opt.style.display = ''; return; }
            var matches = !selected || opt.getAttribute('data-depto') === selected;
            opt.style.display = matches ? '' : 'none';
            opt.disabled = !matches;
            if (opt.value === currentMuni && matches) foundCurrent = true;
        });
        if (!foundCurrent) muni.value = '';
    }

    depto.addEventListener('change', filter);
    filter();
})();
</script>
