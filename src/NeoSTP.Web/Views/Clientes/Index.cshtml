@model NeoSTP.Application.Common.PagedResult<NeoSTP.Application.Clientes.Dtos.ClienteDto>
@{
    ViewData["Title"] = "Clientes";
    var search = ViewBag.Search as string;
}

@if (TempData["Success"] is string ok) { <div class="alert alert-success">@ok</div> }
@if (TempData["Error"] is string err) { <div class="alert alert-danger">@err</div> }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h4 m-0">Clientes</h1>
    <a asp-action="Create" class="btn btn-primary btn-sm">+ Nuevo cliente</a>
</div>

<form method="get" class="row g-2 mb-3">
    <div class="col-auto">
        <input name="search" value="@search" class="form-control form-control-sm" placeholder="Buscar nombre, documento o NRC…" />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-outline-secondary btn-sm">Buscar</button>
    </div>
</form>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover m-0 align-middle">
            <thead class="table-light">
                <tr>
                    <th>Documento</th>
                    <th>Nombre</th>
                    <th>NRC</th>
                    <th>Tipo</th>
                    <th>Correo</th>
                    <th>Estado</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (Model is null || !Model.Items.Any())
                {
                    <tr><td colspan="7" class="text-center text-muted py-4">Sin clientes.</td></tr>
                }
                @foreach (var c in Model?.Items ?? Array.Empty<NeoSTP.Application.Clientes.Dtos.ClienteDto>())
                {
                    var badge = c.EstadoCodigo == "ACTIVO" ? "bg-success" : "bg-secondary";
                    var tipoBadge = c.EsContribuyente ? "bg-info" : "bg-light text-dark border";
                    <tr>
                        <td><strong>@c.TipoDocumentoCodigo</strong> @c.NumeroDocumento</td>
                        <td>@c.Nombre<br /><small class="text-muted">@c.NombreComercial</small></td>
                        <td>@(c.Nrc ?? "—")</td>
                        <td><span class="badge @tipoBadge">@c.TipoContribuyenteCodigo</span></td>
                        <td><small class="text-muted">@c.Correo</small></td>
                        <td><span class="badge @badge">@c.EstadoCodigo</span></td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@c.Id" class="btn btn-sm btn-outline-primary">Editar</a>
                            @if (c.EstadoCodigo == "ACTIVO")
                            {
                                <form asp-action="Inactivar" asp-route-id="@c.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-sm btn-outline-danger" onclick="return confirm('¿Inactivar este cliente?');">Inactivar</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (Model is not null && Model.TotalPages > 1)
{
    <nav class="mt-3"><ul class="pagination pagination-sm">
        @for (int i = 1; i <= Model.TotalPages; i++)
        {
            <li class="page-item @(i == Model.Page ? "active" : "")">
                <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-search="@search">@i</a>
            </li>
        }
    </ul></nav>
}

<p class="text-muted small mt-2">Total: @(Model?.Total ?? 0) clientes.</p>
