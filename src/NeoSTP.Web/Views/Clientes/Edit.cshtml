@model NeoSTP.Web.Models.EditClienteViewModel
@{
    ViewData["Title"] = $"Editar {Model.Nombre}";
    var estados = new[] { "ACTIVO", "INACTIVO" };
}

<h1 class="h4 mb-3">Editar cliente · <span class="text-muted">@Model.Nombre</span></h1>

<form asp-action="Edit" method="post" class="card border-0 shadow-sm p-4" style="max-width: 920px;">
    <input type="hidden" asp-for="Id" />
    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert" style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>

    <partial name="_Form" model="(NeoSTP.Web.Models.CreateClienteViewModel)Model" />

    <div class="mt-3" style="max-width: 240px;">
        <label asp-for="EstadoCodigo" class="form-label"></label>
        <select asp-for="EstadoCodigo" class="form-select">
            @foreach (var e in estados) { <option value="@e" selected="@(e == Model.EstadoCodigo)">@e</option> }
        </select>
    </div>

    <div class="d-flex gap-2 mt-4">
        <button type="submit" class="btn btn-primary">Guardar</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
    </div>
</form>

@section Scripts { @await Html.PartialAsync("_ValidationScriptsPartial") }
