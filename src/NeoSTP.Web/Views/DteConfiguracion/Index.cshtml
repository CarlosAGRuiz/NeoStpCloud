@model NeoSTP.Web.Models.DteConfiguracionViewModel
@{
    ViewData["Title"] = "Configuración DTE";
    var ambientes = (ViewBag.Ambientes as IEnumerable<NeoSTP.Application.Catalogos.Dtos.CatalogoItemDto>) ?? Array.Empty<NeoSTP.Application.Catalogos.Dtos.CatalogoItemDto>();
    var tiposEst = (ViewBag.TiposEstablecimiento as IEnumerable<NeoSTP.Application.Catalogos.Dtos.CatalogoItemDto>) ?? Array.Empty<NeoSTP.Application.Catalogos.Dtos.CatalogoItemDto>();
}

@if (TempData["Success"] is string ok) { <div class="alert alert-success">@ok</div> }
@if (TempData["Error"] is string err) { <div class="alert alert-danger">@err</div> }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h4 m-0">Configuración DTE / Hacienda</h1>
    <span class="badge @(Model.EsCompleto ? "bg-success" : "bg-warning text-dark") fs-6">
        @(Model.EsCompleto ? "Configuración completa" : "Configuración incompleta")
    </span>
</div>

<div class="row g-4">
    <!-- Bloque emisor + credenciales -->
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white"><strong>Datos del emisor y credenciales MH</strong></div>
            <div class="card-body">
                <form asp-action="Save" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert" style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="AmbienteCodigo" class="form-label"></label>
                            <select asp-for="AmbienteCodigo" class="form-select">
                                @foreach (var a in ambientes)
                                {
                                    <option value="@a.Codigo" selected="@(a.Codigo == Model.AmbienteCodigo)">@a.Valor</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="TipoEstablecimientoCodigo" class="form-label"></label>
                            <select asp-for="TipoEstablecimientoCodigo" class="form-select">
                                <option value="">—</option>
                                @foreach (var t in tiposEst)
                                {
                                    <option value="@t.Codigo" selected="@(t.Codigo == Model.TipoEstablecimientoCodigo)">@t.Valor</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="CodigoEstablecimientoMh" class="form-label"></label>
                            <input asp-for="CodigoEstablecimientoMh" class="form-control" placeholder="01" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="CodigoPuntoVentaMh" class="form-label"></label>
                            <input asp-for="CodigoPuntoVentaMh" class="form-control" placeholder="01" />
                        </div>

                        <div class="col-12"><hr class="my-1" /></div>

                        <div class="col-md-6">
                            <label asp-for="UsuarioMh" class="form-label"></label>
                            <input asp-for="UsuarioMh" class="form-control" autocomplete="off" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="PasswordMh" class="form-label"></label>
                            <input asp-for="PasswordMh" type="password" class="form-control" autocomplete="new-password" placeholder="@(Model.TienePasswordMh ? "•••••••• (configurado)" : "")" />
                            @if (Model.TienePasswordMh)
                            {
                                <div class="form-text text-success">✓ Password configurado y cifrado. Vacío = mantener actual.</div>
                            }
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary">Guardar</button>
                        <form asp-action="ProbarConexion" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-success" formaction="@Url.Action("ProbarConexion")">⚡ Probar conexión</button>
                        </form>
                    </div>
                </form>
            </div>
        </div>

        @if (Model.UltimaPruebaAt is not null)
        {
            var alertClass = Model.UltimaPruebaResultado == "OK" ? "alert-success" : "alert-danger";
            <div class="alert @alertClass mt-3 mb-0">
                <strong>Última prueba:</strong> @Model.UltimaPruebaAt?.ToString("yyyy-MM-dd HH:mm") · <strong>@Model.UltimaPruebaResultado</strong>
                <br /><small>@Model.UltimaPruebaDetalle</small>
            </div>
        }
    </div>

    <!-- Bloque certificado -->
    <div class="col-lg-5">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white"><strong>Certificado de firma</strong></div>
            <div class="card-body">
                @if (Model.TieneCertificado)
                {
                    <div class="mb-3">
                        <div><strong>📄 @Model.CertificadoNombre</strong></div>
                        <div class="small text-muted">huella SHA1: <code>@Model.CertificadoHuella</code></div>
                        @if (Model.CertificadoVence is not null)
                        {
                            var diasRest = (Model.CertificadoVence.Value - DateTime.UtcNow).Days;
                            var venceBadge = diasRest < 0 ? "bg-danger" : diasRest < 30 ? "bg-warning text-dark" : "bg-success";
                            <div class="mt-1">
                                <span class="badge @venceBadge">Vence @Model.CertificadoVence.Value.ToString("yyyy-MM-dd")
                                    @(diasRest < 0 ? "(VENCIDO)" : $"({diasRest} días)")
                                </span>
                            </div>
                        }
                    </div>
                    <form asp-action="EliminarCertificado" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-danger btn-sm" onclick="return confirm('¿Eliminar el certificado actual?');">Eliminar certificado</button>
                    </form>
                    <hr />
                    <p class="small text-muted">Reemplazar:</p>
                }

                <form asp-action="UploadCertificado" method="post" enctype="multipart/form-data">
                    <div class="mb-3">
                        <label class="form-label">Archivo (.crt o .pfx)</label>
                        <input type="file" name="Archivo" class="form-control" accept=".crt,.cer,.pfx,.p12" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Password del certificado</label>
                        <input type="password" name="Password" class="form-control" autocomplete="new-password" />
                        <div class="form-text">Opcional. Se cifra con DataProtection.</div>
                    </div>
                    <div class="row g-2 mb-3">
                        <div class="col-6">
                            <label class="form-label">Emitido</label>
                            <input type="date" name="Emitido" class="form-control form-control-sm" />
                        </div>
                        <div class="col-6">
                            <label class="form-label">Vence</label>
                            <input type="date" name="Vence" class="form-control form-control-sm" />
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary btn-sm">Cargar certificado</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts { @await Html.PartialAsync("_ValidationScriptsPartial") }
