@model NeoSTP.Application.Common.PagedResult<NeoSTP.Application.Usuarios.Dtos.UsuarioDto>
@{
    ViewData["Title"] = "Usuarios";
    var search = ViewBag.Search as string;
}

@if (TempData["Success"] is string ok) { <div class="alert alert-success">@ok</div> }
@if (TempData["Error"] is string err) { <div class="alert alert-danger">@err</div> }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h4 m-0">Usuarios</h1>
    <a asp-action="Create" class="btn btn-primary btn-sm">+ Nuevo usuario</a>
</div>

<form method="get" class="row g-2 mb-3">
    <div class="col-auto">
        <input name="search" value="@search" class="form-control form-control-sm" placeholder="Buscar usuario, email o nombre…" />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-outline-secondary btn-sm">Buscar</button>
    </div>
</form>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover m-0 align-middle">
            <thead class="table-light">
                <tr>
                    <th>Usuario</th>
                    <th>Nombre</th>
                    <th>Email</th>
                    <th>Tipo</th>
                    <th>Estado</th>
                    <th>Roles</th>
                    <th>Último login</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (Model is null || !Model.Items.Any())
                {
                    <tr><td colspan="8" class="text-center text-muted py-4">Sin usuarios.</td></tr>
                }
                @foreach (var u in Model?.Items ?? Array.Empty<NeoSTP.Application.Usuarios.Dtos.UsuarioDto>())
                {
                    var badgeClass = u.EstadoCodigo switch {
                        "ACTIVO" => "bg-success",
                        "BLOQUEADO" => "bg-danger",
                        "INACTIVO" => "bg-secondary",
                        _ => "bg-warning text-dark"
                    };
                    <tr>
                        <td><strong>@u.Username</strong></td>
                        <td>@u.NombreCompleto</td>
                        <td><span class="text-muted">@u.Email</span></td>
                        <td><span class="badge bg-info">@u.TipoUsuarioCodigo</span></td>
                        <td><span class="badge @badgeClass">@u.EstadoCodigo</span></td>
                        <td>
                            @foreach (var r in u.RoleCodigos) { <span class="badge bg-light text-dark border me-1">@r</span> }
                        </td>
                        <td class="small text-muted">@(u.UltimoLogin?.ToString("yyyy-MM-dd HH:mm") ?? "—")</td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@u.Id" class="btn btn-sm btn-outline-primary">Editar</a>
                            @if (u.EstadoCodigo == "BLOQUEADO")
                            {
                                <form asp-action="Desbloquear" asp-route-id="@u.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-sm btn-outline-success">Desbloquear</button>
                                </form>
                            }
                            else
                            {
                                <form asp-action="Bloquear" asp-route-id="@u.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-sm btn-outline-danger" onclick="return confirm('¿Bloquear este usuario?');">Bloquear</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (Model is not null && Model.TotalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination pagination-sm">
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.Page ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-search="@search">@i</a>
                </li>
            }
        </ul>
    </nav>
}

<p class="text-muted small mt-2">Total: @(Model?.Total ?? 0) usuarios.</p>
